{"version":3,"kind":"Article","sha256":"a61304fbbcca2d4d6ee4c1b8812298edf7a13ab9286dce6910a78af306769060","slug":"xjsformvalidation","location":"/xJSFormValidation.md","dependencies":[],"frontmatter":{"title":"Form Validation","content_includes_title":false,"authors":[{"nameParsed":{"literal":"James Goudy","given":"James","family":"Goudy"},"name":"James Goudy","id":"contributors-a_books\\CSCI211_csbook\\myst-generated-uid-0"}],"github":"https://github.com/executablebooks/jupyter-book","keywords":["JavaScript","TypeScript"],"copyright":"2026","exports":[{"format":"md","filename":"xJSFormValidation.md","url":"/CSCI211/build/xJSFormValidation-01e51d55a28068af5c3e42b0ca4afc3e.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"This example uses a “flag” approach.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xtcoSydklM"}],"key":"ri5iSiwyke"}],"key":"QuXFbIfK5Y"},{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Lecture Code","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"oVn4jAZdsH"}],"identifier":"lecture-code","label":"Lecture Code","html_id":"lecture-code","implicit":true,"key":"xgF11C7EJy"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"index.html","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Nw5mnjMhsw"}],"key":"vG8epk4v96"},{"type":"code","lang":"html","value":"<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width\">\n    <title>Form Validation Example</title>\n    <!-- Programmer: James Goudy -->\n\n    <style>\n      #theContent{\n        width: 25%;\n        margin: 100px auto;\n        background-color: bisque;\n        padding: 40px;\n        color: black;\n      }\n      #errorDiv{\n        background-color: khaki;\n        color: navy;\n      }\n    </style>\n  </head>\n\n  <body>\n    <div id=\"theContent\">\n      <h1>Form Validation Example</h1>\n\n      <form name=\"demo\" onsubmit=\"return validateFormOnSubmit(this)\" action=\"test.html\">\n        <table summary=\"Demonstration form\">\n          <tbody>\n            <tr>\n              <td><label for=\"username\">Username:</label></td>\n              <td>\n                <input type=\"text\" id=\"username\" name=\"username\" size=\"35\" maxlength=\"50\">\n              </td>\n            </tr>\n            <tr>\n              <td><label for=\"pwd\">Password:</label></td>\n              <td>\n                <input type=\"password\" id=\"pwd\" name=\"pwd\" size=\"35\" maxlength=\"25\">\n              </td>\n            </tr>\n            <tr>\n              <td><label for=\"email\">Email:</label></td>\n              <td>\n                <input type=\"text\" id=\"email\" name=\"email\" size=\"35\" maxlength=\"30\"\n                       placeholder=\"xxx@domain.xxx\">\n              </td>\n            </tr>\n\n            <!-- Leave altEmail as HTML validation example (pattern + required) -->\n            <tr>\n              <td><label for=\"altemail\">Alternate email:</label></td>\n              <td>\n                <input type=\"text\" id=\"altemail\" name=\"altemail\" size=\"35\" maxlength=\"30\"\n                       pattern=\"[a-z0-9._%+\\-]+@[a-z0-9.\\-]+\\.[a-z]{2,}$\"\n                       placeholder=\"xxx@domain.xxx\" required>\n              </td>\n            </tr>\n\n            <tr>\n              <td><label for=\"phone\">Phone:</label></td>\n              <td>\n                <input type=\"text\" id=\"phone\" name=\"phone\" size=\"35\" maxlength=\"25\"\n                       placeholder=\"(555) 555-5555\">\n              </td>\n            </tr>\n            <tr>\n              <td><label for=\"from\">Where are you:</label></td>\n              <td>\n                <input type=\"text\" id=\"from\" name=\"from\" size=\"35\" maxlength=\"50\">\n              </td>\n            </tr>\n            <tr>\n              <td>&nbsp;</td>\n              <td><input name=\"Submit\" value=\"Send\" type=\"submit\"></td>\n              <td>&nbsp;</td>\n            </tr>\n          </tbody>\n        </table>\n      </form>\n\n      <div id=\"errorDiv\"></div>\n    </div>\n\n    <script>\n      /*\n        Demo form validation.\n        - One function per field\n        - Each validator returns \"\" (no error) or \"<li>...</li>\" (error)\n        - Invalid fields are highlighted yellow\n        - On submit, errors are collected and displayed\n      */\n\n      function trim(s) {\n        return s.replace(/^\\s+|\\s+$/, '');\n      }\n\n      function validateFormOnSubmit(theForm) {\n        let reason = \"\";\n\n        // Clear previous errors every submit attempt (fixed casing)\n        document.getElementById(\"errorDiv\").innerHTML = \"\";\n\n        reason += validateUsername(theForm.username);\n        reason += validatePassword(theForm.pwd);\n        reason += validateEmail(theForm.email);\n        reason += validatePhone(theForm.phone);\n        reason += validateEmpty(theForm.from);\n\n        if (reason !== \"\") {\n          reason = \"<h2>Errors</h2><ul>\" + reason + \"</ul><br>\";\n          document.getElementById(\"errorDiv\").innerHTML = reason;\n          return false;\n        }\n\n        // no errors\n        return true;\n      }\n\n      /*\n        Checks if a required field is blank.\n      */\n      function validateEmpty(fld) {\n        let error = \"\";\n        let value = trim(fld.value);\n\n        if (value.length === 0) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The required field has not been filled in.</li>\";\n        } else {\n          fld.style.background = 'White';\n        }\n        return error;\n      }\n\n      /*\n        Username rules:\n        - Not empty\n        - Length 5..15\n        - Only letters, numbers, underscores\n      */\n      function validateUsername(fld) {\n        let error = \"\";\n        let value = trim(fld.value);\n        let illegalChars = /\\W/; // anything other than [A-Za-z0-9_]\n\n        if (value === \"\") {\n          fld.style.background = 'Yellow';\n          error = \"<li>You didn't enter a username.</li>\";\n        } else if (value.length < 5 || value.length > 15) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The username is the wrong length.</li>\";\n        } else if (illegalChars.test(value)) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The username contains illegal characters.</li>\";\n        } else {\n          fld.style.background = 'White';\n        }\n        return error;\n      }\n\n      /*\n        Password rules:\n        - Not empty\n        - Length 7..15\n        - Only letters and numbers (no underscores, no symbols)\n        - Must contain at least one letter and at least one digit\n      */\n      function validatePassword(fld) {\n        let error = \"\";\n        let value = trim(fld.value);\n        let illegalChars = /[\\W_]/; // forbid non-word chars and underscore\n\n        if (value === \"\") {\n          fld.style.background = 'Yellow';\n          error = \"<li>You didn't enter a password.</li>\";\n        } else if (value.length < 7 || value.length > 15) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The password is the wrong length.</li>\";\n        } else if (illegalChars.test(value)) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The password contains illegal characters.</li>\";\n        } else if (!(/[A-Za-z]/.test(value) && /\\d/.test(value))) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The password must contain at least one letter and one numeral.</li>\";\n        } else {\n          fld.style.background = 'White';\n        }\n        return error;\n      }\n\n      /*\n        Email rules (simple demo):\n        - Not empty\n        - Basic pattern check\n        - Reject a few \"illegal\" punctuation characters\n      */\n      function validateEmail(fld) {\n        let error = \"\";\n        let tfld = trim(fld.value);\n\n        // simple-ish email filter (demo purpose, not RFC complete)\n        let emailFilter = /^[^@]+@[^@.]+\\.[^@]*\\w\\w$/;\n        let illegalChars = /[\\(\\)\\<\\>\\,\\;\\:\\\\\\\"\\[\\]]/;\n\n        if (tfld === \"\") {\n          fld.style.background = 'Yellow';\n          error = \"<li>You didn't enter an email address.</li>\";\n        } else if (!emailFilter.test(tfld)) {\n          fld.style.background = 'Yellow';\n          error = \"<li>Please enter a valid email address.</li>\";\n        } else if (illegalChars.test(tfld)) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The email address contains illegal characters.</li>\";\n        } else {\n          fld.style.background = 'White';\n        }\n        return error;\n      }\n\n      /*\n        Phone rules:\n        - Not empty\n        - Strip non-digits\n        - Must be exactly 10 digits\n      */\n      function validatePhone(fld) {\n        let error = \"\";\n        let value = trim(fld.value);\n\n        // keep digits only\n        let digits = value.replace(/\\D/g, '');\n\n        if (value === \"\") {\n          fld.style.background = 'Yellow';\n          error = \"<li>You didn't enter a phone number.</li>\";\n        } else if (digits.length !== 10) {\n          fld.style.background = 'Yellow';\n          error = \"<li>The phone number is the wrong length. Make sure you included an area code.</li>\";\n        } else {\n          fld.style.background = 'White';\n        }\n        return error;\n      }\n    </script>\n  </body>\n</html>\n\n","position":{"start":{"line":9,"column":1},"end":{"line":260,"column":1}},"key":"trh9qGJdce"},{"type":"paragraph","position":{"start":{"line":262,"column":1},"end":{"line":262,"column":1}},"children":[{"type":"text","value":"test.html","position":{"start":{"line":262,"column":1},"end":{"line":262,"column":1}},"key":"zVj6xzdrho"}],"key":"vRv9n4rqiK"},{"type":"code","lang":"html","value":"<html>\n<head>\n<title>test success</title>\n</head>\n\t<style>\n\t\t#theContent{\n\t\t\twidth: 25%;\n\t\t\tmargin: 100px auto; /* Combined margin properties */\n\t\t\tbackground-color: bisque;\n\t\t\tpadding: 40px;\n\t\t\tcolor: black;\n\t\t}\n\t</style>\n<body>\n\t<div id=\"theContent\">\n\t\t<h1>Good test</h1>\n\t\t<p>There was good form validation</p>\n\t</div>\n\n</body>\n</html>","position":{"start":{"line":264,"column":1},"end":{"line":286,"column":1}},"key":"Rlx3b5BAVh"},{"type":"heading","depth":2,"position":{"start":{"line":290,"column":1},"end":{"line":290,"column":1}},"children":[{"type":"text","value":"Explanation","position":{"start":{"line":290,"column":1},"end":{"line":290,"column":1}},"key":"yo9WiNgeFJ"}],"identifier":"explanation","label":"Explanation","html_id":"explanation","implicit":true,"key":"VtMKLenN4E"},{"type":"paragraph","position":{"start":{"line":292,"column":1},"end":{"line":292,"column":1}},"children":[{"type":"text","value":"This document implements a simple HTML form with client-side validation. Validation is performed in two different ways: most fields are validated with custom JavaScript on form submission, while the “Alternate email” field is validated using built-in HTML5 constraints (","position":{"start":{"line":292,"column":1},"end":{"line":292,"column":1}},"key":"sTrVI1wPkK"},{"type":"inlineCode","value":"required","position":{"start":{"line":292,"column":1},"end":{"line":292,"column":1}},"key":"jBjFTcsylN"},{"type":"text","value":" and ","position":{"start":{"line":292