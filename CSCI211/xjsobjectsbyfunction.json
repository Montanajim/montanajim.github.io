{"version":3,"kind":"Article","sha256":"7a3d2e4d53cc4ec376127f212cc4c90a409dbb0c915ca52c41dbce7becebd41f","slug":"xjsobjectsbyfunction","location":"/xJSObjectsByFunction.md","dependencies":[],"frontmatter":{"title":"Objects By Function","content_includes_title":false,"authors":[{"nameParsed":{"literal":"James Goudy","given":"James","family":"Goudy"},"name":"James Goudy","id":"contributors-a_books\\CSCI211_csbook\\myst-generated-uid-0"}],"github":"https://github.com/executablebooks/jupyter-book","keywords":["JavaScript","TypeScript"],"copyright":"2026","exports":[{"format":"md","filename":"xJSObjectsByFunction.md","url":"/CSCI211/build/xJSObjectsByFunction-75dba095c3db071704a0b88a55f30337.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Create objects by use of a function.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UZJ1tgrSoI"}],"key":"nkM8lryMr2"},{"type":"heading","depth":2,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Lecture Code","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"zkT6Nq4PGs"}],"identifier":"lecture-code","label":"Lecture Code","html_id":"lecture-code","implicit":true,"key":"eH32TD8nyT"},{"type":"code","lang":"html","value":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <title>Objects By Function</title>\n  <style>\n    .theContent {\n      width: 25%;\n      margin: 100px auto; /* Combines margin properties for top/bottom and left/right centering */\n      background-color: bisque;\n      padding: 40px;\n      color: black;\n    }\n\n    #numppl {\n      width: 50px;\n    }\n  </style>\n  <script>\n    function Person(fname, lname, city) {\n      this.fname = fname;\n      this.lname = lname;\n      this.city = city;\n      this.fullname = () => {\n        return this.fname + \" \" + this.lname + \", \" + this.city;\n      }\n    }\n\n    // Lists containing names and cities for random generation\n    let firstList = [\"John\", \"Mary\", \"Abe\", \"Jim\", \"Stanley\", \"Salley\", \"Ann\"];\n    let lastList = [\"Rodes\", \"Smith\", \"Miller\", \"Jones\", \"Stucci\", \"Kindreck\", \"Patton\"];\n    let cityList = [\"Kali\", \"Polson\", \"Libby\", \"Whitefish\", \"Dayton\", \"Noxon\", \"Bozeman\"];\n\n    let people = new Array(); // Array to store Person objects\n\n    // Function to generate a random integer between 0 (inclusive) and max (inclusive)\n    function RandomIntMax(max) {\n      // + 1 to make the max inclusive\n      return Math.floor(Math.random() * (max + 1));\n    }\n\n    function createPeople() {\n\n      people.length = 0;\n\n      let numPeople = Number(document.getElementById(\"numppl\").value);\n\n      if (numPeople > 25) {\n        numPeople = 25;\n      }\n\n      for (let i = 0; i < numPeople; i++) {\n        const rfname = firstList[RandomIntMax(firstList.length - 1)];\n        const rlname = lastList[RandomIntMax(lastList.length - 1)];\n        const rcity = cityList[RandomIntMax(cityList.length - 1)];\n\n        const xperson = new Person(rfname, rlname, rcity); // Use `new` keyword to create a new Person object\n        people[i] = xperson;\n      }\n\n      document.getElementById(\"numppl\").value = '';\n      displayPeople();\n    }\n\n\n    // Function to display the full names and cities of all Person objects in the people array\n    function displayPeople() {\n      let strpeople = \"\";\n\n      for (let i = 0; i < people.length; i++) {\n        strpeople += people[i].fullname() + \"\\n<br>\"; // Use the fullname method of each Person object\n      }\n      console.log(strpeople);\n      document.getElementById(\"ppl\").innerHTML = strpeople;\n    }\n  </script>\n</head>\n\n<body>\n  <div class=\"theContent\">\n    <h1>Objects By Function</h1>\n\n    <br><hr><br>\n\n    <label for=\"numppl\">Enter the number of people:</label>\n    <input type=\"number\" name=\"numppl\" id=\"numppl\" min=\"0\" max=\"25\" value=\"0\" placeholder=\"1-25\">\n    <button onclick=\"createPeople()\">Enter</button>\n\n    <p id=\"ppl\"></p>\n\n    <p><a href=\"index.html\">Objects By Class</a></p>\n  </div>\n</body>\n\n</html>\n","position":{"start":{"line":9,"column":1},"end":{"line":107,"column":1}},"key":"qQudtASUOe"},{"type":"heading","depth":2,"position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"children":[{"type":"text","value":"Explaination","position":{"start":{"line":111,"column":1},"end":{"line":111,"column":1}},"key":"XboHe2eb5p"}],"identifier":"explaination","label":"Explaination","html_id":"explaination","implicit":true,"key":"lECntyVvmB"},{"type":"paragraph","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"children":[{"type":"text","value":"This code creates a webpage that allows users to generate a random list of people with full names and cities. Here’s a breakdown of the different parts:","position":{"start":{"line":113,"column":1},"end":{"line":113,"column":1}},"key":"o1YxQtx50y"}],"key":"RgJLmijBLB"},{"type":"paragraph","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"strong","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"children":[{"type":"text","value":"HTML (Structure and Appearance):","position":{"start":{"line":115,"column":1},"end":{"line":115,"column":1}},"key":"XDXjC1SUYb"}],"key":"VFB9C3HZKX"}],"key":"A6CH8ME4oD"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":117,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":117,"column":1},"end":{"line":118,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":117,"column":1},"end":{"line":117,"column