":31,"column":1}},"key":"bZ7EW0HQFi"}],"key":"CM0xAcVCXl"},{"type":"text","value":" Subclasses can override inherited methods from the parent class to provide their own implementation. This allows for customization of behavior specific to the subclass.","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"JYFoAluvi1"}],"key":"MSaSzKv7pr"}],"key":"T9ANZd5Y1A"},{"type":"heading","depth":2,"position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Lecture Code","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"brpCMo4r7i"}],"identifier":"lecture-code","label":"Lecture Code","html_id":"lecture-code","implicit":true,"key":"fodGYUHzqy"},{"type":"code","lang":"html","value":"<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width\">\n  <title>Objects By Class</title>\n  <style>\n    .theContent {\n      width: 40%;\n      margin: 100px auto;\n      background-color: bisque;\n      padding: 40px;\n      color: black;\n    }\n  </style>\n  <script>\n    class Person {\n      constructor(fname, lname) {\n        this.fname = fname;\n        this.lname = lname;\n      }\n\n      getFullName() {\n        return `${this.fname} ${this.lname}`;\n      }\n    }\n\n    // ------- End Of Class --------------\n\n    class Student extends Person {\n      constructor(fname, lname, college, major) {\n        super(fname, lname); // Call the parent class constructor\n        this.college = college;\n        this.major = major;\n      }\n\n      allinfo() {\n        return `${this.fname} ${this.lname} - ${this.college}, ${this.major}`;\n      }\n\n      nameinfo() {\n        return `${this.fname} ${this.lname}`;\n      }\n    }\n\n    // ------- End Of Class --------------\n\n    // Lists containing names and cities for random generation\n    let firstList = [\"John\", \"Mary\", \"Abe\", \"Jim\", \"Stanley\", \"Salley\", \"Ann\"];\n    let lastList = [\"Rodes\", \"Smith\", \"Miller\", \"Jones\", \"Stucci\", \"Kindreck\", \"Patton\"];\n    let collegeList = [\"MSU\", \"UM\", \"Montana Tech\", \"Ohio State\", \"Stanford\", \"FVCC\", \"MIT\"];\n    let majorList = [\"Comp Sci\", \"Engineering\", \"Theater\", \"Math\", \"Geology\", \"AI\", \"Pre Med\", \"Pre Law\"];\n    let people = new Array(); // Array to store Person objects\n\n    // Function to generate a random integer between 0 (inclusive) and max (inclusive)\n    function RandomIntMax(max) {\n      // + 1 to make the max inclusive\n      return Math.floor(Math.random() * (max + 1));\n    }\n\n    // Function to create a specified number of Person objects with random names and cities\n    function createPeople() {\n      people.length = 0;\n      let numPeople = Number(document.getElementById(\"numppl\").value);\n      if (numPeople > 25) {\n        numPeople = 25;\n      }\n      for (let i = 0; i < numPeople; i++) {\n        let rfname = firstList[RandomIntMax(firstList.length - 1)];\n        let rlname = lastList[RandomIntMax(lastList.length - 1)];\n        let rcollege = collegeList[RandomIntMax(collegeList.length - 1)];\n        let rmajor = majorList[RandomIntMax(majorList.length - 1)];\n        let xperson = new Student(rfname, rlname, rcollege, rmajor);\n        people[i] = xperson;\n      }\n      document.getElementById(\"numppl\").value = \"\";\n      displayPeople();\n    }\n\n    // Function to display the full names and cities of all Person objects in the people array\n    function displayPeople() {\n      let strpeople = \"\";\n      strpeople += \" <ol>\";\n      for (let i = 0; i < people.length; i++) {\n        strpeople +=\n          ` <li> ${people[i].getFullName()} <br> ${people[i].allinfo()} <br> <br> </li>`;\n      }\n      strpeople += \" </ol>\";\n      document.getElementById(\"ppl\").innerHTML = strpeople;\n    }\n  </script>\n</head>\n\n<body>\n  <div class=\"theContent\">\n    <h1>Inheritance</h1>\n    <br><hr><br>\n    <label for=\"numppl\">Enter the number of people:</label>\n    <input type=\"number\" id=\"numppl\" min=\"0\" max=\"25\" value=\"0\" placeholder=\"1-25\">\n    <button onclick=\"createPeople()\">Enter</button>\n    <p id=\"ppl\"></p>\n  </div>\n</body>\n\n</html>\n","position":{"start":{"line":37,"column":1},"end":{"line":145,"column":1}},"key":"LIFECDZtHo"},{"type":"heading","depth":2,"position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"children":[{"type":"text","value":"Explanation","position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"key":"TkoKORGGqJ"}],"identifier":"explanation","label":"Explanation","html_id":"explanation","implicit":true,"key":"HbKiIEoSgs"},{"type":"paragraph","position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"children":[{"type":"text","value":"This code creates a simple web page that allows you to generate a list of random student objects. Here’s a breakdown of the different sections:","position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"key":"ziYeb3hnCB"}],"key":"nVWXiLagur"},{"type":"paragraph","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"strong","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"children":[{"type":"text","value":"HTML (Structure and Styling):","position":{"start":{"line":153,"column":1},"end":{"line":153,"column":1}},"key":"VLsCBohVah"}],"key":"Z5i4tc2XCy"}],"key":"ir3fhRhSML"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":155,"column":1},"end":{"line":159,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":155,"column":1},"end":{"line":155,"column":1}},"children":[{"type":"text","value":"The HTML portion of the code defines the structure of the webpage using elements like ","position":{"start":{"line":155,"column":1},"end":{"line":155,"column":1}},"key":"Ht8Lfj7D7