", \"Los Angeles\", \"Chicago\", \"Houston\"];","position":{"start":{"line":19,"column":1},"end":{"line":21,"column":1}},"key":"MySVeHQ96L"},{"type":"thematicBreak","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"BUfIpfZjdv"},{"type":"heading","depth":2,"position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Accessing Array Elements","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"gQN5H4gGjL"}],"identifier":"accessing-array-elements","label":"Accessing Array Elements","html_id":"accessing-array-elements","implicit":true,"key":"D5SjSblV0R"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"Array elements are accessed using bracket notation and an index.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"TL4myndZIo"}],"key":"zgA8Rokowv"},{"type":"code","lang":"javascript","value":"cities[0]; // first element\ncities[2]; // third element","position":{"start":{"line":29,"column":1},"end":{"line":32,"column":1}},"key":"g7YTxX4Oso"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"If an index does not exist, JavaScript returns ","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"s2mIzHouUR"},{"type":"inlineCode","value":"undefined","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"TzgYPlp9s7"},{"type":"text","value":". It does not throw an error.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"XIkr34gEyw"}],"key":"m3r2DDE3Sy"},{"type":"thematicBreak","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"N8XbtSJXi1"},{"type":"heading","depth":2,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Mutating vs Non-Mutating Operations","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"R98UQp3vkD"}],"identifier":"mutating-vs-non-mutating-operations","label":"Mutating vs Non-Mutating Operations","html_id":"mutating-vs-non-mutating-operations","implicit":true,"key":"yxO2PQZMDb"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Some array methods ","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"mEqQDFPNLc"},{"type":"strong","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"change the original array","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"cuT2e6hJJD"}],"key":"VFbRffNesV"},{"type":"text","value":". Others return new values and leave the original unchanged. This lesson demonstrates both, and each case is labeled clearly. Ignoring this distinction causes bugs later.","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"jyU0LXubJQ"}],"key":"XxKkZb07AI"},{"type":"thematicBreak","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"aiG9suyVhD"},{"type":"heading","depth":2,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"Lecture Code","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"H3VEv5iwyq"}],"identifier":"lecture-code","label":"Lecture Code","html_id":"lecture-code","implicit":true,"key":"eTOi3kYzVv"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"This example demonstrates common array operations and displays their effects directly in the browser. The code is intentionally linear and explicit.","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"ZbcY9jP9WM"}],"key":"LHaHGwMUU3"},{"type":"heading","depth":3,"position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"Complete Example (Using ","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"SRVNu2wSI4"},{"type":"inlineCode","value":"querySelector","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"aVpegc4okr"},{"type":"text","value":")","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"iK1d1HGc73"}],"identifier":"complete-example-using-queryselector","label":"Complete Example (Using querySelector)","html_id":"complete-example-using-queryselector","implicit":true,"key":"r2jj13o8RW"},{"type":"code","lang":"javascript","value":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width\">\n    <title>JavaScript Arrays</title>\n\n    <style>\n        .heading {\n            color: blue;\n            font-weight: bold;\n        }\n        .block {\n            margin-bottom: 1em;\n        }\n    </style>\n\n    <script>\n        function write(tagId, html) {\n            document.querySelector(\"#\" + tagId).innerHTML = html;\n        }\n\n        function printArray(arr, tagId, heading) {\n            const output = arr.join(\"<br>\");\n\n            write(tagId,\n                \"<div class='block'>\" +\n                \"<div class='heading'>\" + heading + \"</div>\" +\n                output +\n                \"</div>\"\n            );\n        }\n\n        function findItem(arr, value) {\n            return arr.indexOf(value);\n        }\n    </script>\n</head>\n\n<body>\n\n<p id=\"p0\"></p>\n<p id=\"p1\"></p>\n<p id=\"p2\"></p>\n<p id=\"p3\"></p>\n<p id=\"p4\"></p>\n<p id=\"p5\"></p>\n<p id=\"p6\"></p>\n<p id=\"p7\"></p>\n<p id=\"p8\"></p>\n<p id=\"p9\"></p>\n<p id=\"p10\"></p>\n<p id=\"p11\"></p>\n<p id=\"p12\"></p>\n<p id=\"p13\"></p>\n<p id=\"p14\"></p>\n<p id=\"p15\"></p>\n\n<script>\n    // Create an array\n    let cities = [\n        \"New York\",\n        \"Los Angeles\",\n        \"Chicago\",\n        \"Houston\",\n        \"Phoenix\",\n        \"San Diego\",\n        \"Dallas\",\n        \"Kalispell\"\n    ];\n\n    printArray(cities, \"p0\", \"Original Array\");\n\n    // Access individual elements\n    write(\"p1\",\n        cities[0] + \"<br>\" +\n        cities[2] + \"<br>\" +\n        cities[4]\n    );\n\n    // pop() removes the last element (mutates the array)\n    let removedCity = cities.pop();\n    printArray(cities, \"p2\", \"After pop() — removed: \" + removedCity);\n\n    // push() adds elements to the end (mutates the array)\n    cities.push(\"Toledo\", \"Big Fork\");\n    printArray(cities, \"p3\", \"After push()\");\n\n    // sort() orders strings alphabetically (mutates the array)\n    cities.sort();\n    printArray(cities, \"p4\", \"After sort()\");\n\n    // reverse() reverses order (mutates the array)\n    cities.reverse();\n    printArray(cities, \"p5\", \"After reverse()\");\n\n    // shift() removes the first element (mutates the array)\n    cities.shift();\n    printArray(cities, \"p6\", \"After shift()\");\n\n    // unshift() adds elements to the beginning (mutates the array)\n    cities.unshift(\"Las Vegas\");\n    printArray(cities, \"p7\", \"After unshift()\");\n\n    // join() creates a string from the array (does NOT mutate)\n    let cityString = cities.join(\" | \");\n    write(\"p8\",\n        \"<div class='heading'>Join Result</div>\" +\n        cityString\n    );\n\n    // split() creates an array from a string\n    let names = \"Jim,Bob,George,Harry,Daryl,Daryl\";\n    let nameArray = names.split(\",\");\n    printArray(nameArray, \"p9\", \"Array Created with split()\");\n\n    // splice() removes elements by index (mutates the array)\n    cities.splice(1, 1);\n    printArray(cities, \"p10\", \"After splice() — remove one item\");\n\n    // splice() can insert elements (mutates the array)\n    cities.splice(1, 0, \"Dillon\", \"Helena\");\n    printArray(cities, \"p11\", \"After splice() — insert items\");\n\n    // slice() creates a new array (does NOT mutate)\n    let subset = cities.slice(2, 5);\n    printArray(subset, \"p12\", \"Result of slice() (new array)\");\n    printArray(cities, \"p13\", \"Original Array After slice()\");\n\n    // indexOf() search — found\n    let searchItem = \"Chicago\";\n    let index = findItem(cities, searchItem);\n\n    write(\"p14\",\n        \"<div class='heading'>Search Result (found)</div>\" +\n        \"Index: \" + index + \"<br>\" +\n        \"Value: \" + cities[index]\n    );\n\n    // indexOf() search — not found\n    searchItem = \"HooBoo\";\n    index = findItem(cities, searchItem);\n\n    write(\"p15\",\n        \"<div class='heading'>Search Result (not found)</div>\" +\n        \"Returned value: \" + index\n    );\n</script>\n\n</body>\n</html>","position":{"start":{"line":50,"column":1},"end":{"line":202,"column":1}},"key":"gIWxY1FUwt"},{"type":"heading","depth":2,"position":{"start":{"line":204,"column":1},"end":{"line":204,"column":1}},"children":[],"key":"qhiV2jr5cp"}],"key":"kJKxwNKRpj"}],"key":"gmfTpEVl4i"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"querySelector vs getElement(s)By","url":"/xqueryselectorvsgetelementsby","group":"Client Side Programming"},"next":{"title":"Random Functions","url":"/xjsrandom","group":"Client Side Programming"}}},"domain":"http://localhost:3000"}